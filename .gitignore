# CMAS (Cognitive Multi-Agent System) - Standard GitIgnore
# ──────────────────────────────────────────────────────────────────────

# Core Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Runtime Mission Data (PRIVATE / DO NOT COMMIT)
# ──────────────────────────────────────────────────────────────────────
.c2_mission_data/
.c2_mission_workspace/
data/
workspace/
logs/
reports/
*.db
*.csv
*.json
project_*/
.env
.clauderoot
.cursorrules

# Config (PRIVATE / DO NOT COMMIT)
# ──────────────────────────────────────────────────────────────────────
config.yaml
personality.yaml
agents_config.json

# IDE / AI Agent Dotfiles (PRIVATE / DO NOT COMMIT)
# ──────────────────────────────────────────────────────────────────────
.*
!/.gitignore
!/.env.example
!/.github/
!/src/
!/setup.sh
!/start.sh
!/README.md
!/LICENSE
!/config.example.yaml
!/configs/
!/main.py
!/requirements.txt

# OS Files
.DS_Store
Thumbs.db
desktop.ini
