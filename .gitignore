# ── Python ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
.eggs/
*.egg-info/
.venv/
venv/
env/

# ── Runtime data (generated by CMAS at runtime — never commit) ───
.cmas/
.guardian/
.c2_mission_data/
.c2_mission_workspace/
*.db
*.sqlite

# ── User config (created by setup.sh — contains secrets) ─────────
.env
config.yaml
personality.yaml

# ── Web frontend build output ─────────────────────────────────────
web/dist/
web/node_modules/

# ── Framework JSON (allow these — they are source, not generated) ─
!src/cmas/frameworks/*.json

# ── Config examples (allow these) ─────────────────────────────────
!config/*.yaml
!config/*.json

# ── IDE / AI agent dotfolders ─────────────────────────────────────
.agent/
.claude/
.codebuddy/
.codex/
.continue/
.cursor/
.gemini/
.kiro/
.opencode/
.qoder/
.roo/
.trae/
.windsurf/
.vscode/
.idea/

# ── OS files ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
