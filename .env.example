# CMAS Environment Variables
# Copy to .env and fill in your keys, or run ./setup.sh

# Required — powers all AI responses
OPENAI_API_KEY=sk-your-key-here

# Optional — enables web search for research tasks
# Get a free key at https://tavily.com
TAVILY_API_KEY=tvly-your-key-here

# Optional — Discord bot
# DISCORD_TOKEN=your-discord-bot-token

# Optional — WhatsApp via Twilio
# TWILIO_ACCOUNT_SID=your-sid
# TWILIO_AUTH_TOKEN=your-token
# TWILIO_WHATSAPP_NUMBER=+14155238886

# Optional overrides
# CMAS_PORT=8080
# CMAS_TIMEZONE=America/New_York
